{
  "name": "pi-auggie-router",
  "version": "1.4.0",
  "description": "Opinionated sub-agent router for Pi: tightly couples SKILL.md execution with the Augment Code (auggie) Context Engine.",
  "author": "pi-auggie-router contributors",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "extension.ts",
    "README.md",
    "GETTING-STARTED.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extension.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungggi/pi-auggie-router.git"
  },
  "homepage": "https://github.com/pungggi/pi-auggie-router#readme",
  "bugs": {
    "url": "https://github.com/pungggi/pi-auggie-router/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "node --test --test-reporter=spec --import tsx tests/**/*.test.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "pi",
    "pi-framework",
    "pi-extension",
    "pi-package",
    "auggie",
    "augment",
    "claude",
    "mcp",
    "skill",
    "subagent",
    "router"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "gray-matter": "4.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "20.11.0",
    "rimraf": "5.0.5",
    "tsx": "4.21.0",
    "typescript": "5.8.3"
  }
}
